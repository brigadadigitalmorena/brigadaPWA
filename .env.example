# API Configuration
# Browser requests use the same-origin proxy at /api/backend (no CORS issues).
# API_URL is used server-side by the Next.js proxy (set this in Vercel).
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# App Configuration
NEXT_PUBLIC_APP_NAME=Brigada Digital
NEXT_PUBLIC_APP_VERSION=1.0.0

# Environment
NODE_ENV=development
